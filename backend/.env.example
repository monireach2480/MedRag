# ── Embedding ──────────────────────────────────────────────
# EMBED_MODEL=BAAI/bge-base-en-v1.5
# EMBED_DIMENSION=768

# ── Embedding (bge-small — fits t2.micro, great quality) ──────────────────────
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIMENSION=384

# ── Chunking (tuned for medical PDFs) ─────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80
MIN_CHUNK_LENGTH=50

# ── RAG ────────────────────────────────────────────────────────────────────────
TOP_K_RESULTS=6
SCORE_THRESHOLD=0.45

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false